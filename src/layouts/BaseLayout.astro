---
import SiteFooter from "@/components/SiteFooter.astro";
import SiteHeader from "@/components/SiteHeader.astro";
import { siteConfig } from "@/config/site";
import { absoluteUrl } from "@/lib/format";
import "@/styles/global.css";

interface Props {
  title?: string;
  description?: string;
  canonical?: string;
  image?: string;
  type?: "website" | "article";
}

const {
  title,
  description = siteConfig.siteDescription,
  canonical = Astro.url.toString(),
  image,
  type = "website",
} = Astro.props;

const pageTitle = title ? `${title} | ${siteConfig.siteTitle}` : `${siteConfig.siteTitle} | ${siteConfig.tagline}`;
const socialImage = image
  ? image.startsWith("http")
    ? image
    : absoluteUrl(image)
  : undefined;
const authorId = absoluteUrl("/about/#author");
const baseStructuredData = [
  {
    "@context": "https://schema.org",
    "@type": "WebSite",
    "@id": absoluteUrl("/#website"),
    url: siteConfig.siteUrl,
    name: siteConfig.siteTitle,
    description: siteConfig.siteDescription,
    inLanguage: "en-AU",
    author: {
      "@id": authorId,
    },
  },
  {
    "@context": "https://schema.org",
    "@type": "Person",
    "@id": authorId,
    name: siteConfig.author.name,
    jobTitle: siteConfig.author.role,
    url: siteConfig.author.url,
    sameAs: siteConfig.author.sameAs,
  },
];
const goatcounter = import.meta.env.PUBLIC_GOATCOUNTER_CODE;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <meta name="theme-color" content="#0d1117" />
    <meta name="robots" content="index,follow,max-image-preview:large" />
    <meta name="googlebot" content="index,follow,max-image-preview:large" />
    <link rel="canonical" href={canonical} />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <meta property="og:site_name" content={siteConfig.siteTitle} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content={type} />
    <meta property="og:url" content={canonical} />
    {socialImage && <meta property="og:image" content={socialImage} />}
    <meta name="twitter:card" content={socialImage ? "summary_large_image" : "summary"} />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    {socialImage && <meta name="twitter:image" content={socialImage} />}
    <link rel="alternate" type="application/rss+xml" title="Daniel Tse RSS" href="/feed.xml" />
    <script is:inline type="application/ld+json" set:html={JSON.stringify(baseStructuredData)}></script>
    {goatcounter && (
      <script
        is:inline
        data-goatcounter={`https://${goatcounter}.goatcounter.com/count`}
        async
        src="//gc.zgo.at/count.js"
      ></script>
    )}
  </head>
  <body>
    <div class="page-shell">
      <div class="page-noise" aria-hidden="true"></div>
      <div class="page-grid">
        <SiteHeader />
        <main class="page-main">
          <slot />
        </main>
        <SiteFooter />
      </div>
    </div>
  </body>
</html>
