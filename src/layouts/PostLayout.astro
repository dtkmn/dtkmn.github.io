---
import ArticleMeta from "@/components/ArticleMeta.astro";
import TagList from "@/components/TagList.astro";
import BaseLayout from "@/layouts/BaseLayout.astro";
import { siteConfig } from "@/config/site";
import { absoluteUrl } from "@/lib/format";

interface Props {
  title: string;
  summary: string;
  date: Date;
  tags: string[];
  canonicalUrl?: string;
  mediumUrl?: string;
  heroImage?: string;
  headings?: { depth: number; slug: string; text: string }[];
  readingTime?: number;
  kind: "article" | "note";
}

const {
  title,
  summary,
  date,
  tags,
  canonicalUrl,
  mediumUrl,
  heroImage,
  headings = [],
  readingTime = 1,
  kind,
} = Astro.props;

const localCanonical = Astro.url.toString();
const pageCanonical = canonicalUrl ?? localCanonical;
const socialImage = heroImage ? (heroImage.startsWith("http") ? heroImage : absoluteUrl(heroImage)) : undefined;
const authorId = absoluteUrl("/about/#author");
const tocItems = headings.filter((heading) => heading.depth === 2 || heading.depth === 3);
const sectionCount = headings.filter((heading) => heading.depth === 2).length;
const readingMode = kind === "article" ? "Deep dive" : "Tactical note";

const jsonLd =
  kind === "article"
    ? {
        "@context": "https://schema.org",
        "@type": "BlogPosting",
        "@id": `${pageCanonical}#article`,
        headline: title,
        description: summary,
        url: pageCanonical,
        datePublished: date.toISOString(),
        dateModified: date.toISOString(),
        inLanguage: "en-AU",
        isPartOf: {
          "@id": absoluteUrl("/#website"),
        },
        author: {
          "@type": "Person",
          "@id": authorId,
          name: siteConfig.author.name,
          url: siteConfig.author.url,
          sameAs: siteConfig.author.sameAs,
        },
        publisher: {
          "@type": "Person",
          "@id": authorId,
          name: siteConfig.author.name,
          url: siteConfig.author.url,
        },
        mainEntityOfPage: {
          "@type": "WebPage",
          "@id": pageCanonical,
        },
        image: socialImage ? [socialImage] : undefined,
        keywords: tags.join(", "),
        isAccessibleForFree: true,
      }
    : undefined;
---

<BaseLayout
  title={title}
  description={summary}
  canonical={pageCanonical}
  image={heroImage}
  type="article"
>
  {jsonLd && (
    <script is:inline type="application/ld+json" set:html={JSON.stringify(jsonLd)}></script>
  )}

  <article class="post-shell">
    <div class="post-intro">
      <p class="post-kicker">{kind === "article" ? "Essay" : "Note"}</p>
      <h1>{title}</h1>
      <p class="post-summary">{summary}</p>
      <ArticleMeta date={date} mediumUrl={mediumUrl} />
      {canonicalUrl && canonicalUrl !== localCanonical && (
        <p class="post-canonical-note">
          This piece is archived here for continuity. The original canonical publication lives on
          <a href={canonicalUrl} rel="noreferrer noopener" target="_blank"> Medium</a>.
        </p>
      )}
      {tags.length > 0 && <TagList tags={tags} />}
    </div>
    <div class="post-body">
      <aside class="post-sidebar">
        <div class="reading-panel">
          <p class="eyebrow">Reading guide</p>
          <ul class="reading-panel-list">
            <li>
              <span>Estimated read</span>
              <strong>{readingTime} min</strong>
            </li>
            <li>
              <span>Structure</span>
              <strong>{sectionCount > 0 ? `${sectionCount} sections` : "Short brief"}</strong>
            </li>
            <li>
              <span>Mode</span>
              <strong>{readingMode}</strong>
            </li>
            {tags.length > 0 && (
              <li>
                <span>Topics</span>
                <strong>{tags.slice(0, 3).join(" / ")}</strong>
              </li>
            )}
          </ul>
        </div>

        {tocItems.length > 0 && (
          <nav class="reading-panel" aria-label="Table of contents">
            <p class="eyebrow">On this page</p>
            <div class="post-toc">
              {tocItems.map((heading) => (
                <a
                  class:list={["post-toc-link", heading.depth === 3 && "post-toc-link--nested"]}
                  href={`#${heading.slug}`}
                >
                  {heading.text}
                </a>
              ))}
            </div>
          </nav>
        )}
      </aside>

      <div class="prose">
        <slot />
      </div>
    </div>
  </article>
</BaseLayout>
