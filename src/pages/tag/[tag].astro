---
import ArticleCard from "@/components/ArticleCard.astro";
import BaseLayout from "@/layouts/BaseLayout.astro";
import { getTagIndex } from "@/lib/content";

export async function getStaticPaths() {
  const tags = await getTagIndex();
  return tags.map((tag) => ({
    params: { tag: tag.slug },
    props: { tag },
  }));
}

const { tag } = Astro.props;
const entries = [...tag.articles, ...tag.notes].sort(
  (a, b) => b.data.date.getTime() - a.data.date.getTime(),
);
---

<BaseLayout title={`Tag: ${tag.label}`} description={`Posts tagged ${tag.label}.`}>
  <section class="page-lead">
    <p class="eyebrow">Topic</p>
    <h1>{tag.label}</h1>
    <p class="page-lead-summary">
      {tag.articles.length} article{tag.articles.length === 1 ? "" : "s"}
      {tag.notes.length > 0 && ` and ${tag.notes.length} note${tag.notes.length === 1 ? "" : "s"}`}.
    </p>
  </section>

  <div class="stack-grid">
    {entries.map((entry) => <ArticleCard entry={entry} />)}
  </div>
</BaseLayout>

