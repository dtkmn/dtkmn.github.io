---
import ArticleCard from "@/components/ArticleCard.astro";
import BaseLayout from "@/layouts/BaseLayout.astro";
import { getPublishedArticles } from "@/lib/content";

const articles = await getPublishedArticles();
---

<BaseLayout title="Articles" description="Essays and archived technical writing by Daniel Tse.">
  <section class="page-lead">
    <p class="eyebrow">Articles</p>
    <h1>Essays, walkthroughs, and archived platform writeups.</h1>
    <p class="page-lead-summary">
      Long-form writing across AI systems, backend engineering, platform operations, and the older
      archive that shaped the current point of view.
    </p>
  </section>

  <div class="stack-grid">
    {articles.map((entry) => <ArticleCard entry={entry} />)}
  </div>
</BaseLayout>

