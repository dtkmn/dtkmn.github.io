    | "articles"
    | "projects"
    | "notes"
    | "about"
    | "github"
    | "linkedin"
    | "rss"
    | "menu"
    | "arrow-right"
    | "archive"
    | "book-open"
    | "calendar"
    | "check-circle"
    | "cloud"
    | "external"
    | "file-text"
    | "flask"
    | "gauge"
    | "layers"
    | "rocket"
    | "server"
    | "shield"
    | "spark"
    | "terminal";
