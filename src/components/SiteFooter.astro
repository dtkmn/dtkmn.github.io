---
import { siteConfig } from "@/config/site";

const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="site-footer-copy">
    <p class="site-footer-title">Benchmarks, systems, and technical writing with proof attached.</p>
    <p>
      Site-first publishing. Repositories, docs, demos, and syndication branch out from here.
    </p>
  </div>
  <div class="site-footer-links">
    {siteConfig.socialLinks
      .filter((link) => ["GitHub", "LinkedIn", "Medium", "RSS"].includes(link.label))
      .map((link) => (
        <a href={link.href} rel="noreferrer noopener" target={link.href.startsWith("http") ? "_blank" : undefined}>
          {link.label}
        </a>
      ))}
  </div>
  <p class="site-footer-meta">© {year} {siteConfig.siteTitle}</p>
</footer>
