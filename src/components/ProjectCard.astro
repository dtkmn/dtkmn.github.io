---
import type { CollectionEntry } from "astro:content";
import UiIcon from "@/components/UiIcon.astro";

interface Props {
  project: CollectionEntry<"projects">;
  variant?: "feature" | "list";
}

const { project, variant = "list" } = Astro.props;
const href = project.data.detailPage ? `/projects/${project.slug}/` : project.data.repoUrl;
const external = !project.data.detailPage;

const statusLabel = {
  active: "Active",
  maintained: "Maintained",
  experimental: "Experimental",
}[project.data.status];
const tierIcon = project.data.tier === "flagship" ? "rocket" : "flask";
---

<article class:list={["article-card", "project-card", `article-card--${variant}`]}>
  <a
    class="article-card-link"
    href={href}
    rel={external ? "noreferrer noopener" : undefined}
    target={external ? "_blank" : undefined}
  >
    {variant === "feature" && project.data.heroImage && (
      <figure class="project-card-media">
        <img src={project.data.heroImage} alt={`${project.data.title} visual`} loading="lazy" />
      </figure>
    )}
    <div class="article-card-copy">
      <p class="article-card-kind">
        <UiIcon name={tierIcon} class="article-card-kind-icon" />
        <span>{project.data.tier === "flagship" ? "Flagship project" : "Supporting project"}</span>
      </p>
      <h3>{project.data.title}</h3>
      <p class="article-card-summary">{project.data.summary}</p>
    </div>
  </a>

  <div class="project-card-footer">
    <div class="project-card-meta">
      <span class:list={["status-pill", `status-pill--${project.data.status}`]}>{statusLabel}</span>
      {external && (
        <span class="project-card-external">
          <UiIcon name="external" class="project-card-external-icon" />
          <span>Repository link</span>
        </span>
      )}
    </div>
    {project.data.stack.length > 0 && (
      <p class="project-card-stack">{project.data.stack.slice(0, 3).join(" / ")}</p>
    )}
  </div>
</article>
